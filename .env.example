# Copy to .env (or set these in your hosting dashboard, e.g. Railway → Variables)

# From Meta for Developers (developers.facebook.com)
WHATSAPP_TOKEN=EAAG...your-permanent-access-token
PHONE_NUMBER_ID=123456789012345
APP_SECRET=your-meta-app-secret

# Any secret string you invent — must match what you type in Meta webhook setup
VERIFY_TOKEN=my-secret-verify-token-2026

# From console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional
ANTHROPIC_MODEL=claude-sonnet-4-5
MAX_HISTORY=20
PAUSE_KEYWORD=#stop
RESUME_KEYWORD=#start

# Owner's phone for booking alerts (private number, full international, digits only)
OWNER_WHATSAPP=353858182839

# Email each booking to an inbox (optional). Leave blank to disable emailing.
# Sent over HTTPS via Resend because Railway blocks outbound SMTP on Hobby plans.
RESEND_API_KEY=re_your_resend_api_key
BOOKING_EMAIL_FROM=onboarding@resend.dev
BOOKING_EMAIL_TO=onlinebookingnctpass@gmail.com
